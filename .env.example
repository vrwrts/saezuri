# BirdNET-Go base URL (REQUIRED).
# In production the nginx container proxies /api/ here, resolved at container
# start. In dev the Vite proxy uses the same value. Point it at your instance:
BIRDNETGO_URL=http://192.168.1.10:8080

# Optional auth token for a BirdNET-Go instance running with Security.PrivateMode.
# nginx injects it as an "Authorization: Bearer <token>" header on proxied /api/
# calls; the browser never receives it. Leave unset for public LAN instances.
# BIRDNETGO_TOKEN=
