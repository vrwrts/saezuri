---

<section class="section wrap" id="features">
  <p class="kicker">What it does</p>
  <h2>A calm, glanceable view of your local birdlife</h2>
  <p class="lede">
    Point it at BirdNET-Go and leave it on a screen. Everything runs on your own network —
    no account, no cloud, no writes.
  </p>
  <div class="features">
    {
      features.map((f) => (
        <div class="feature">
          <span class="dot"></span>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))
    }
  </div>
</section>
